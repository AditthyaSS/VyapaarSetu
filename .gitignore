/node_modules/.prisma

# ─── Testing ─────────────────────────────────────────────────────
/coverage

# ─── Misc ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.pem

# ─── Debug logs ──────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Vercel ──────────────────────────────────────────────────────
.vercel

# ─── TypeScript ──────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts
