# ─── Dependencies ────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# ─── Environment & Secrets (NEVER commit these) ──────────────────
.env
.env.*
!.env.example

# ─── Next.js ─────────────────────────────────────────────────────
/.next/
/out/
/build

# ─── Prisma ──────────────────────────────────────────────────────
